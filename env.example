# LeakIX API anahtarı — https://leakix.net adresinden ücretsiz hesap açıp alabilirsiniz.
# Boş bırakılırsa leakix_service.py anonim/limitli erişimle devam eder.
LEAKIX_API_KEY=""

# AlienVault OTX API anahtarı — https://otx.alienvault.com/api adresinden hesabınızın
# ayarlar sayfasından ("API Integration") alabilirsiniz.
OTX_API_KEY=""

# Opsiyonel: mevcut XposedOrNot entegrasyonunuz bir API anahtarı gerektiriyorsa buraya ekleyin.
XPOSEDORNOT_API_KEY=""

# Veritabanı bağlantısı (mevcut projenizle uyumlu olacak şekilde düzenleyin)
DATABASE_URL="sqlite:///./leaks.db"

# --- Bildirim Sistemi (opsiyonel — her ikisi de boş bırakılabilir) ---
# Telegram: @BotFather'dan token, chat_id için botu eklediğiniz grup/kanal id'si
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Slack: Incoming Webhook URL (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=""
